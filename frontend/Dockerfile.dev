# Imagen de DESARROLLO para docker-compose (NO se usa en Vercel).
# Vercel construye el frontend con su propio pipeline; este Dockerfile es
# solo para levantar el dev server localmente dentro de un contenedor.
FROM node:20-slim
WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

EXPOSE 5173

# --host hace que Vite sea accesible desde fuera del contenedor.
CMD ["npm", "run", "dev", "--", "--host", "--port", "5173"]
