# Imagen de DESARROLLO para docker-compose (NO se usa en Cloud Run).
# Instala todas las dependencias, sincroniza el esquema con la BD y arranca
# el servidor en modo watch con recarga en caliente.
FROM node:20-slim
WORKDIR /app

# Prisma necesita openssl
RUN apt-get update -y && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
RUN npm install

COPY prisma ./prisma
RUN npx prisma generate

COPY . .

EXPOSE 8080

# Aplica las migraciones versionadas (prisma/migrations/*), corre los seeders
# (idempotentes, guardados por SeederLog) y levanta el server en watch.
# Requiere haber generado la migración inicial: `npx prisma migrate dev --name init`.
CMD ["sh", "-c", "npx prisma migrate deploy && (npm run prisma:seed || echo 'seed omitido') && npm run start:dev"]
