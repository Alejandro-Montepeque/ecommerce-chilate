# Base de datos Neon (Postgres serverless). Panel Neon -> Connection string.
# Usa la cadena "pooled" para runtime y añade ?sslmode=require
DATABASE_URL="postgresql://usuario:password@ep-xxx-pooler.region.aws.neon.tech/chilate?sslmode=require"

# Secreto para firmar los JWT (genera uno largo y aleatorio)
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"

# Orígenes permitidos por CORS (tu dominio de Vercel), separados por coma
CORS_ORIGINS="http://localhost:5173"

# Puerto (Cloud Run inyecta PORT automáticamente)
PORT=8080
