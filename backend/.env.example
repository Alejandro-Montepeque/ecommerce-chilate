# Base de datos Neon (Postgres serverless). Panel Neon -> Connection string.
# Usa la cadena "pooled" para runtime y añade ?sslmode=require
DATABASE_URL="postgresql://usuario:password@ep-xxx-pooler.region.aws.neon.tech/chilate?sslmode=require"

# Secreto para firmar los JWT (genera uno largo y aleatorio)
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"

# Orígenes permitidos por CORS (tu dominio de Vercel), separados por coma
CORS_ORIGINS="http://localhost:5173"

# Puerto (Cloud Run inyecta PORT automáticamente; NO lo definas en Cloud Run)
PORT=8080

# Zona horaria del servidor. Necesaria para que la regla de descuentos
# ("a partir del día siguiente") use la hora local de El Salvador.
TZ=America/El_Salvador

# Google Cloud Storage para imágenes (opcional).
# Si no se define GCS_BUCKET, el backend responde 503 y el front usa base64.
GCS_BUCKET="ecommerce-chilate"
# GCS_PROJECT_ID es opcional: si se omite, se toma del JSON de credenciales.
# En LOCAL: ruta al JSON de la service account (en Cloud Run no hace falta).
GOOGLE_APPLICATION_CREDENTIALS="./ecommercechilate-73d70610d476.json"
# URL pública del backend (para las URLs de imágenes servidas por proxy).
PUBLIC_API_URL="http://localhost:8080/api"

# Correos con Gmail SMTP (opcional; si faltan, el envío se omite).
# GMAIL_APP_PASSWORD es una "contraseña de aplicación" de 16 caracteres.
GMAIL_USER="tucorreo@gmail.com"
GMAIL_APP_PASSWORD="xxxxxxxxxxxxxxxx"
