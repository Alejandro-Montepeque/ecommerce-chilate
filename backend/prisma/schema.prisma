// Esquema Prisma — Chilate ecommerce
// Base de datos: PostgreSQL (Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  MAINTENANCE
  CATALOG
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID_SIMULATED
  CANCELLED
  FULFILLED
}

// Subcategoría fija del producto (para navegar Categoría › Subcategoría).
enum Subcategory {
  HOMBRE
  MUJER
  UNISEX
}

model User {
  id        String         @id @default(uuid())
  email     String         @unique
  password  String // hash bcrypt
  fullName  String?
  role      Role           @default(CUSTOMER)
  orders    Order[]
  wishlist  WishlistItem[]
  createdAt DateTime       @default(now())
}

// Lista de deseos (por usuario autenticado).
model WishlistItem {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

// Descuento programado por producto (con rango de fechas).
model Discount {
  id        String   @id @default(uuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  percent   Int // 1-100
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())
}

model Category {
  id        String    @id @default(uuid())
  slug      String    @unique
  nameEs    String
  nameEn    String
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
}

// Catálogo de tallas gestionable desde el panel.
model Size {
  id        String   @id @default(uuid())
  label     String   @unique // S, M, L, 38...
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// Catálogo de colores gestionable desde el panel.
model Color {
  id        String   @id @default(uuid())
  name      String   @unique
  hex       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Collection {
  id            String              @id @default(uuid())
  slug          String              @unique
  nameEs        String
  nameEn        String
  descriptionEs String?
  descriptionEn String?
  isActive      Boolean             @default(true)
  products      ProductCollection[]
  createdAt     DateTime            @default(now())
}

model Product {
  id            String              @id @default(uuid())
  slug          String              @unique
  nameEs        String
  nameEn        String
  descriptionEs String?
  descriptionEn String?
  priceUsd      Decimal             @db.Decimal(10, 2)
  isPublished   Boolean             @default(false)
  category      Category?           @relation(fields: [categoryId], references: [id])
  categoryId    String?
  subcategory   Subcategory? // Hombre / Mujer / Unisex (opcional)
  variants      ProductVariant[]
  images        ProductImage[]
  collections   ProductCollection[]
  discounts     Discount[]
  wishlistItems WishlistItem[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model ProductCollection {
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId    String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId String

  @@id([productId, collectionId])
}

model ProductImage {
  id        String  @id @default(uuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  url       String
  altEs     String?
  altEn     String?
  sortOrder Int     @default(0)
}

// Variante = combinación talla/color con su propio inventario
model ProductVariant {
  id               String      @id @default(uuid())
  product          Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId        String
  sku              String?     @unique
  size             String?
  color            String?
  colorHex         String?
  priceOverrideUsd Decimal?    @db.Decimal(10, 2)
  stock            Int         @default(0)
  isActive         Boolean     @default(true)
  orderItems       OrderItem[]

  @@unique([productId, size, color])
}

// Contenido editable de la landing (autogestión)
model Banner {
  id         String   @id @default(uuid())
  titleEs    String?
  titleEn    String?
  subtitleEs String?
  subtitleEn String?
  imageUrl   String?
  linkUrl    String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model SiteContent {
  key       String   @id // ej. hero_title, footer_about
  valueEs   String?
  valueEn   String?
  updatedAt DateTime @updatedAt
}

model Order {
  id              String      @id @default(uuid())
  user            User?       @relation(fields: [userId], references: [id])
  userId          String?
  guestEmail      String?
  status          OrderStatus @default(PENDING)
  currency        String      @default("USD")
  subtotalUsd     Decimal     @db.Decimal(10, 2)
  totalUsd        Decimal     @db.Decimal(10, 2)
  shippingName    String?
  shippingAddress String?
  shippingPhone   String?
  paymentRef      String?
  items           OrderItem[]
  createdAt       DateTime    @default(now())
}

model OrderItem {
  id           String          @id @default(uuid())
  order        Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      String
  variant      ProductVariant? @relation(fields: [variantId], references: [id])
  variantId    String?
  productName  String
  size         String?
  color        String?
  unitPriceUsd Decimal         @db.Decimal(10, 2)
  quantity     Int
}
